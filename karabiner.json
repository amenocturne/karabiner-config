{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Toggle CAPS_LOCK with LEFT_SHIFT + RIGHT_SHIFT",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "left_shift",
                                    "modifiers": { "mandatory": ["right_shift"], "optional": ["caps_lock"] }
                                },
                                "to": [{ "key_code": "caps_lock" }],
                                "to_if_alone": [{ "key_code": "left_shift" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "right_shift",
                                    "modifiers": { "mandatory": ["left_shift"], "optional": ["caps_lock"] }
                                },
                                "to": [{ "key_code": "caps_lock" }],
                                "to_if_alone": [{ "key_code": "right_shift" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "CAPS_LOCK : set hyper variable or ESCAPE (if alone)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "set_variable": { "name": "hyper", "value": 1 } }
                                ],
                                "to_after_key_up": [
                                    { "set_variable": { "name": "hyper", "value": 0 } }
                                ],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            },
                            {
                                "description": "Avoid sysdiagnose cmd+shift+option+ctrl+,",
                                "from": { "key_code": "comma", "modifiers": { "mandatory": ["command", "shift", "option", "control"] } },
                                "to": [],
                                "type": "basic"
                            },
                            {
                                "description": "Avoid sysdiagnose cmd+shift+option+ctrl+.",
                                "from": { "key_code": "period", "modifiers": { "mandatory": ["command", "shift", "option", "control"] } },
                                "to": [],
                                "type": "basic"
                            },
                            {
                                "description": "Avoid sysdiagnose cmd+shift+option+ctrl+/",
                                "from": { "key_code": "slash", "modifiers": { "mandatory": ["command", "shift", "option", "control"] } },
                                "to": [],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Yabai window management (hyper = caps_lock held)",
                        "manipulators": [
                            {
                                "description": "hyper-h: warp west",
